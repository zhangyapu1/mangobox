{
  "name": "mangobox",
  "version": "1.0.0",
  "description": "PC端TVBox完整克隆 - Electron + Vue 3 + mpv + Python Spider",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "vite --config vite.config.ts",
    "electron:build": "vite build && electron-builder --win",
    "postinstall": "electron-builder install-app-deps"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhangyapu1/mangobox.git"
  },
  "keywords": [
    "tvbox",
    "electron",
    "vue3",
    "video",
    "iptv",
    "mangobox"
  ],
  "author": "MangoBox",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/zhangyapu1/mangobox/issues"
  },
  "homepage": "https://github.com/zhangyapu1/mangobox#readme",
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.7",
    "vue-tsc": "^2.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.1.0",
    "naive-ui": "^2.38.0",
    "pinia": "^2.1.0",
    "sql.js": "^1.10.0",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0"
  }
}
